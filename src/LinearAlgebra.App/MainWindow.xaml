<Window x:Class="LinearAlgebra.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:views="clr-namespace:LinearAlgebra.App.Views"
        xmlns:rendering="clr-namespace:LinearAlgebra.App.Rendering"
        xmlns:converters="clr-namespace:LinearAlgebra.App.Converters"
        Title="Linear Algebra — Visual Learning"
        Width="1280" Height="800" MinWidth="900" MinHeight="600"
        Background="{StaticResource BgBrush}"
        WindowStartupLocation="CenterScreen">

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="200" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="120" />
        </Grid.RowDefinitions>

        <!-- Left: Navigation -->
        <views:NavigationPanel Grid.Column="0" Grid.Row="0" Grid.RowSpan="2"
                               DataContext="{Binding Navigation}" />

        <!-- Center + Right: Lesson content (canvas + control panel) -->
        <Grid Grid.Column="1" Grid.Row="0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <!-- Canvas -->
            <rendering:SkiaCanvasControl x:Name="Canvas" Grid.Column="0" />

            <!-- Right panel comes from lesson DataTemplate -->
            <ContentControl Grid.Column="1" Content="{Binding ActiveLesson}" />
        </Grid>

        <!-- Bottom: Explanation + Quiz -->
        <views:ExplanationPanel Grid.Column="1" Grid.Row="1"
                                DataContext="{Binding ActiveLesson}" />

        <!-- Theme/Sound toggle (top right corner overlay) -->
        <StackPanel Grid.Column="1" Grid.Row="0" Orientation="Horizontal"
                    HorizontalAlignment="Right" VerticalAlignment="Top"
                    Margin="0,8,260,0" Opacity="0.8">
            <StackPanel Orientation="Horizontal" Margin="4,0">
                <TextBlock Text="Dark" Foreground="{StaticResource TextSecondaryBrush}" FontSize="11" VerticalAlignment="Center" Margin="0,0,4,0" />
                <RadioButton IsChecked="{Binding IsDarkTheme}" Foreground="{StaticResource TextBrush}" VerticalAlignment="Center" />
                <TextBlock Text="Light" Foreground="{StaticResource TextSecondaryBrush}" FontSize="11" VerticalAlignment="Center" Margin="4,0,0,0" />
                <RadioButton IsChecked="{Binding IsDarkTheme, Converter={StaticResource InverseBool}}" Foreground="{StaticResource TextBrush}" VerticalAlignment="Center" />
            </StackPanel>
            <Button Content="{Binding IsMuted, Converter={x:Static converters:MuteButtonConverter.Instance}}"
                    Command="{Binding ToggleMuteCommand}" Style="{StaticResource PresetButton}"
                    Margin="8,0,0,0" Padding="8,4" FontSize="11" />
        </StackPanel>
    </Grid>
</Window>

<Application x:Class="LinearAlgebra.App.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:converters="clr-namespace:LinearAlgebra.App.Converters">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="Resources/Colors.xaml" />
                <ResourceDictionary Source="Resources/Styles.xaml" />
                <ResourceDictionary Source="Resources/DataTemplates.xaml" />
            </ResourceDictionary.MergedDictionaries>

            <!-- Global converters -->
            <converters:BoolToVisibilityConverter x:Key="BoolVis" />
            <converters:InverseBoolToVisibilityConverter x:Key="InverseBoolVis" />
            <converters:IndexToBoolConverter x:Key="IndexConverter" />
            <converters:StringMatchConverter x:Key="AnswerConverter" />
            <converters:InverseBoolConverter x:Key="InverseBool" />
        </ResourceDictionary>
    </Application.Resources>
</Application>

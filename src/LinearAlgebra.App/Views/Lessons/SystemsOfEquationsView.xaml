<UserControl x:Class="LinearAlgebra.App.Views.Lessons.SystemsOfEquationsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:converters="clr-namespace:LinearAlgebra.App.Converters">
    <DockPanel>
        <Border DockPanel.Dock="Right" Width="250" Background="{StaticResource PanelBrush}"
                BorderBrush="{StaticResource BorderBrush}" BorderThickness="1,0,0,0">
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <StackPanel Margin="12">
                    <TextBlock Text="Equation 1" Style="{StaticResource SectionHeader}" Foreground="#50A0FF" />
                    <StackPanel Orientation="Horizontal" Margin="0,4">
                        <TextBox Text="{Binding A1, UpdateSourceTrigger=LostFocus}" Style="{StaticResource MatrixTextBox}" Width="45" />
                        <TextBlock Text="x +" Foreground="{StaticResource TextBrush}" VerticalAlignment="Center" Margin="4,0" />
                        <TextBox Text="{Binding B1, UpdateSourceTrigger=LostFocus}" Style="{StaticResource MatrixTextBox}" Width="45" />
                        <TextBlock Text="y =" Foreground="{StaticResource TextBrush}" VerticalAlignment="Center" Margin="4,0" />
                        <TextBox Text="{Binding C1, UpdateSourceTrigger=LostFocus}" Style="{StaticResource MatrixTextBox}" Width="45" />
                    </StackPanel>

                    <TextBlock Text="Equation 2" Style="{StaticResource SectionHeader}" Foreground="#64DC64" />
                    <StackPanel Orientation="Horizontal" Margin="0,4">
                        <TextBox Text="{Binding A2, UpdateSourceTrigger=LostFocus}" Style="{StaticResource MatrixTextBox}" Width="45" />
                        <TextBlock Text="x +" Foreground="{StaticResource TextBrush}" VerticalAlignment="Center" Margin="4,0" />
                        <TextBox Text="{Binding B2, UpdateSourceTrigger=LostFocus}" Style="{StaticResource MatrixTextBox}" Width="45" />
                        <TextBlock Text="y =" Foreground="{StaticResource TextBrush}" VerticalAlignment="Center" Margin="4,0" />
                        <TextBox Text="{Binding C2, UpdateSourceTrigger=LostFocus}" Style="{StaticResource MatrixTextBox}" Width="45" />
                    </StackPanel>

                    <Separator Background="{StaticResource BorderBrush}" Margin="0,12" />

                    <TextBlock Text="Presets" Style="{StaticResource SectionHeader}" />
                    <WrapPanel>
                        <Button Content="Intersecting" Style="{StaticResource PresetButton}" Command="{Binding SetIntersectingCommand}" />
                        <Button Content="Parallel" Style="{StaticResource PresetButton}" Command="{Binding SetParallelCommand}" />
                        <Button Content="Coincident" Style="{StaticResource PresetButton}" Command="{Binding SetCoincidentCommand}" />
                    </WrapPanel>

                    <!-- Quiz mode answer options -->
                    <StackPanel Visibility="{Binding IsQuizMode, Converter={StaticResource BoolVis}}" Margin="0,16,0,0">
                        <TextBlock Text="How many solutions?" Style="{StaticResource SectionHeader}" />
                        <RadioButton Content="One solution" Foreground="{StaticResource TextBrush}"
                                     IsChecked="{Binding SelectedAnswer, Converter={StaticResource AnswerConverter}, ConverterParameter='One solution'}" Margin="0,4" />
                        <RadioButton Content="No solution" Foreground="{StaticResource TextBrush}"
                                     IsChecked="{Binding SelectedAnswer, Converter={StaticResource AnswerConverter}, ConverterParameter='No solution'}" Margin="0,4" />
                        <RadioButton Content="Infinitely many" Foreground="{StaticResource TextBrush}"
                                     IsChecked="{Binding SelectedAnswer, Converter={StaticResource AnswerConverter}, ConverterParameter='Infinitely many solutions'}" Margin="0,4" />
                        <Button Content="Submit" Style="{StaticResource PresetButton}" Command="{Binding SubmitQuizAnswerCommand}" Margin="0,8" />
                    </StackPanel>
                </StackPanel>
            </ScrollViewer>
        </Border>
        <Border />
    </DockPanel>
</UserControl>

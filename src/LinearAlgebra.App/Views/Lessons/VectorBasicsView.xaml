<UserControl x:Class="LinearAlgebra.App.Views.Lessons.VectorBasicsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <DockPanel>
        <!-- Right control panel -->
        <Border DockPanel.Dock="Right" Width="250" Background="{StaticResource PanelBrush}"
                BorderBrush="{StaticResource BorderBrush}" BorderThickness="1,0,0,0">
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <StackPanel Margin="12">
                    <TextBlock Text="Vector Controls" Style="{StaticResource SectionHeader}" />

                    <TextBlock Text="X Component" Foreground="{StaticResource TextSecondaryBrush}" FontSize="12" Margin="0,8,0,2" />
                    <Slider Value="{Binding VectorX}" Minimum="-8" Maximum="8"
                            TickFrequency="0.5" IsSnapToTickEnabled="True" />
                    <TextBlock Text="{Binding VectorX, StringFormat='{}{0:F1}'}"
                               Foreground="{StaticResource TextBrush}" FontFamily="Consolas" HorizontalAlignment="Center" />

                    <TextBlock Text="Y Component" Foreground="{StaticResource TextSecondaryBrush}" FontSize="12" Margin="0,8,0,2" />
                    <Slider Value="{Binding VectorY}" Minimum="-8" Maximum="8"
                            TickFrequency="0.5" IsSnapToTickEnabled="True" />
                    <TextBlock Text="{Binding VectorY, StringFormat='{}{0:F1}'}"
                               Foreground="{StaticResource TextBrush}" FontFamily="Consolas" HorizontalAlignment="Center" />

                    <Separator Background="{StaticResource BorderBrush}" Margin="0,12" />

                    <CheckBox IsChecked="{Binding ShowComponents}" Foreground="{StaticResource TextBrush}"
                              Content="Show Components" Margin="0,4" />

                    <Separator Background="{StaticResource BorderBrush}" Margin="0,12" />

                    <TextBlock Text="Properties" Style="{StaticResource SectionHeader}" />
                    <TextBlock Foreground="{StaticResource TextBrush}" FontFamily="Consolas" FontSize="12">
                        <Run Text="Magnitude: " /><Run Text="{Binding Magnitude, StringFormat='{}{0:F2}', Mode=OneWay}" />
                    </TextBlock>
                    <TextBlock Foreground="{StaticResource TextBrush}" FontFamily="Consolas" FontSize="12">
                        <Run Text="Angle: " /><Run Text="{Binding Angle, StringFormat='{}{0:F1} deg', Mode=OneWay}" />
                    </TextBlock>

                    <TextBlock Text="Drag the arrowhead to move the vector"
                               Foreground="{StaticResource TextSecondaryBrush}" FontSize="11"
                               TextWrapping="Wrap" Margin="0,16,0,0" FontStyle="Italic" />
                </StackPanel>
            </ScrollViewer>
        </Border>

        <!-- Canvas fills remaining space (handled by parent) -->
        <Border />
    </DockPanel>
</UserControl>

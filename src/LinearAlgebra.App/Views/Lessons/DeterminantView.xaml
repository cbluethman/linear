<UserControl x:Class="LinearAlgebra.App.Views.Lessons.DeterminantView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:converters="clr-namespace:LinearAlgebra.App.Converters">
    <UserControl.Resources>
        <converters:BoolToVisibilityConverter x:Key="BoolVis" />
    </UserControl.Resources>
    <DockPanel>
        <Border DockPanel.Dock="Right" Width="250" Background="{StaticResource PanelBrush}"
                BorderBrush="{StaticResource BorderBrush}" BorderThickness="1,0,0,0">
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <StackPanel Margin="12">
                    <TextBlock Text="Matrix [2x2]" Style="{StaticResource SectionHeader}" />
                    <Grid Margin="0,8">
                        <Grid.RowDefinitions>
                            <RowDefinition />
                            <RowDefinition />
                        </Grid.RowDefinitions>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition />
                            <ColumnDefinition Width="8" />
                            <ColumnDefinition />
                        </Grid.ColumnDefinitions>
                        <TextBox Grid.Row="0" Grid.Column="0" Text="{Binding M11, UpdateSourceTrigger=LostFocus}" Style="{StaticResource MatrixTextBox}" />
                        <TextBox Grid.Row="0" Grid.Column="2" Text="{Binding M12, UpdateSourceTrigger=LostFocus}" Style="{StaticResource MatrixTextBox}" />
                        <TextBox Grid.Row="1" Grid.Column="0" Text="{Binding M21, UpdateSourceTrigger=LostFocus}" Style="{StaticResource MatrixTextBox}" Margin="0,4,0,0" />
                        <TextBox Grid.Row="1" Grid.Column="2" Text="{Binding M22, UpdateSourceTrigger=LostFocus}" Style="{StaticResource MatrixTextBox}" Margin="0,4,0,0" />
                    </Grid>

                    <Separator Background="{StaticResource BorderBrush}" Margin="0,12" />

                    <TextBlock Text="Determinant" Style="{StaticResource SectionHeader}" />
                    <TextBlock FontSize="24" FontWeight="Bold" FontFamily="Consolas"
                               HorizontalAlignment="Center" Margin="0,8">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="Foreground" Value="#50A0FF" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding Determinant, Converter={x:Static converters:IsNegativeConverter.Instance}}" Value="True">
                                        <Setter Property="Foreground" Value="#FF6464" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                        <Run Text="{Binding Determinant, StringFormat='{}{0:F2}', Mode=OneWay}" />
                    </TextBlock>

                    <TextBlock Text="Area scaling factor. Negative = orientation flipped."
                               Foreground="{StaticResource TextSecondaryBrush}" FontSize="11"
                               TextWrapping="Wrap" Margin="0,4" FontStyle="Italic" />

                    <!-- Quiz answer input -->
                    <StackPanel Visibility="{Binding IsQuizMode, Converter={StaticResource BoolVis}}" Margin="0,12,0,0">
                        <TextBlock Text="Your answer:" Foreground="{StaticResource TextSecondaryBrush}" FontSize="12" />
                        <TextBox Text="{Binding QuizAnswer, UpdateSourceTrigger=PropertyChanged}"
                                 Style="{StaticResource MatrixTextBox}" Width="120" Margin="0,4" />
                        <Button Content="Submit" Style="{StaticResource PresetButton}" Command="{Binding SubmitQuizAnswerCommand}" />
                    </StackPanel>
                </StackPanel>
            </ScrollViewer>
        </Border>
        <Border />
    </DockPanel>
</UserControl>
